{
  "version": 2,
  "global_rules": {
    "display": {
      "integer_only": true
    },
    "direct_effect": {
      "exclude_from_status_signed_rules": true
    },
    "signed_policy": {
      "description": "Signed values represent additive deltas that can be combined with other passive, family, buff, or debuff sources."
    },
    "status_params": {
      "ATTACK": {
        "type": "modifier",
        "field": "attackMultiplierPerMil",
        "inc_field": "attackMultiplierIncrementPerLevelPerMil",
        "signed": true
      },
      "DEFENSE": {
        "type": "modifier",
        "field": "defenseMultiplierPerMil",
        "inc_field": "defenseMultiplierIncrementPerLevelPerMil",
        "signed": true
      },
      "MANAREGEN": {
        "type": "modifier",
        "field": "manaGenerationMultiplierPerMil",
        "inc_field": "manaGenerationMultiplierIncrementPerLevelPerMil",
        "signed": true
      },
      "CRIT": {
        "type": "percent",
        "field": "critIncrementPerMil",
        "inc_field": "incrementPerLevelPerMil",
        "signed": true
      },
      "HEALTH": {
        "type": "percent",
        "field": "healthPercentRecoveryPerMil",
        "signed": true
      }
    }
  },
  "family_rules": {},
  "skill_rules": {
