        "MANAREGEN": {
          "type": "modifier",
          "field": "manaGenerationMultiplierPerMil",
          "inc_field": "manaGenerationMultiplierIncrementPerLevelPerMil",
          "signed": true
        },
        "CRIT": {
          "type": "percent",
          "field": "critIncrementPerMil",
          "inc_field": "incrementPerLevelPerMil",
          "signed": true
        },
        "HEALTH": {
          "type": "percent",
          "field": "healthPercentRecoveryPerMil",
          "signed": true
        }
      }
